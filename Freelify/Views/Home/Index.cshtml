@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section class="py-5 bg-light rounded-4 shadow-sm">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <h1 class="display-4 fw-bold mb-3">
                    Find the Right Freelancer
                    <span class="text-primary">for Every Job</span>
                </h1>

                <p class="lead text-muted mb-4">
                    Freelify connects talented freelancers with trusted clients.
                    Post projects, hire professionals, and grow your career.
                </p>

                <a asp-controller="Job"
                   asp-action="Browse"
                   class="btn btn-primary btn-lg me-3">

                    <i class="bi bi-search"></i>
                    Browse Jobs

                </a>

                <a asp-controller="Account"
                   asp-action="Register"
                   class="btn btn-outline-primary btn-lg">

                    <i class="bi bi-person-plus"></i>
                    Join Now

                </a>

            </div>

            <div class="col-lg-6 text-center">

                <div class="col-lg-6 text-center">

    <img src="~/images/download.jpg"
         class="img-fluid"
         style="max-height:420px;"
         alt="Freelify Hero" />

</div>


            </div>

        </div>

    </div>

</section>


<!-- Statistics -->

<div class="container mt-5">

    <div class="row text-center">

        <div class="col-md-3">

            <h2 class="fw-bold text-primary">500+</h2>
            <p class="text-muted">Projects</p>

        </div>

        <div class="col-md-3">

            <h2 class="fw-bold text-success">200+</h2>
            <p class="text-muted">Freelancers</p>

        </div>

        <div class="col-md-3">

            <h2 class="fw-bold text-warning">150+</h2>
            <p class="text-muted">Clients</p>

        </div>

        <div class="col-md-3">

            <h2 class="fw-bold text-info">24/7</h2>
            <p class="text-muted">Support</p>

        </div>

    </div>

</div>



<!-- Features -->

<div class="container mt-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">Why Freelify?</h2>

        <p class="text-muted">
            Everything you need to hire or work as a freelancer.
        </p>

    </div>

    <div class="row g-4">

        <div class="col-lg-3 col-md-6">

            <div class="card h-100 shadow-sm border-0">

                <div class="card-body text-center">

                    <i class="bi bi-person-workspace display-4 text-primary"></i>

                    <h4 class="mt-3">

                        Freelancers

                    </h4>

                    <p class="text-muted">

                        Build your profile and apply for projects.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card h-100 shadow-sm border-0">

                <div class="card-body text-center">

                    <i class="bi bi-briefcase-fill display-4 text-success"></i>

                    <h4 class="mt-3">

                        Clients

                    </h4>

                    <p class="text-muted">

                        Publish projects and hire the best talent.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card h-100 shadow-sm border-0">

                <div class="card-body text-center">

                    <i class="bi bi-shield-check display-4 text-warning"></i>

                    <h4 class="mt-3">

                        Secure

                    </h4>

                    <p class="text-muted">

                        Authentication powered by ASP.NET Identity.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card h-100 shadow-sm border-0">

                <div class="card-body text-center">

                    <i class="bi bi-chat-dots-fill display-4 text-info"></i>

                    <h4 class="mt-3">

                        Communication

                    </h4>

                    <p class="text-muted">

                        Connect easily with clients and freelancers.

                    </p>

                </div>

            </div>

        </div>

    </div>

</div>



<!-- CTA -->

<section class="container mt-5">

    <div class="bg-primary text-white rounded-4 p-5 text-center">

        <h2 class="fw-bold">

            Ready to Start?

        </h2>

        <p class="lead">

            Join Freelify today and start your freelancing journey.

        </p>

        <a asp-controller="Account"
           asp-action="Register"
           class="btn btn-light btn-lg">

            Create Account

        </a>

    </div>

</section>