<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Freelify</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Freelify.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">

    @RenderSection("Styles", required: false)

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- Logo -->
                <a class="navbar-brand fw-bold fs-2 text-primary"
                   asp-controller="Home"
                   asp-action="Index">
                    Freelify
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- Center Menu -->
                    <ul class="navbar-nav mx-auto">

                        <li class="nav-item mx-2">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>
                                Home
                            </a>
                        </li>

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item mx-2">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>
                                    Login
                                </a>
                            </li>
                        }

                    </ul>

                </div>

            </div>
        </nav>

                    @*     @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Job" asp-action="MyJobs">
                                        <i class="bi bi-briefcase me-1"></i> My Jobs
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Job" asp-action="Create">
                                        <i class="bi bi-plus-circle me-1"></i> Create Job
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Freelancer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="JobBrowse" asp-action="Index">
                                        <i class="bi bi-search me-1"></i> Browse Jobs
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Application" asp-action="MyApplications">
                                        <i class="bi bi-file-earmark-text me-1"></i> My Applications
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Category" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i> Manage Categories
                                    </a>
                                </li>
                            }
                        }

                    </ul>


                    <ul class="navbar-nav ms-auto">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle me-1"></i> Profile
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="LogOut">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                            </li>

                            @* <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Register
                                </a>
                            </li> *@
                        @* } *@

      @*               </ul> 

                </div>
            </div>
        </nav> *@
    </header>
    
    @if (User.Identity.IsAuthenticated)
    {
        <partial name="_Sidebar" />
    }

    <div id="main-content" class="main-content">
        <partial name="_Alerts" />
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
