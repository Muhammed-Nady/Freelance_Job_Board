<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Freelify</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Freelify.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">

    @RenderSection("Styles", required: false)

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold fs-3"
                   asp-controller="Home"
                   asp-action="Index">
                    Freelify
                </a>                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse ms-lg-4" id="navbarNav">
                   
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i> Home
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Job" asp-action="MyJobs">
                                        <i class="bi bi-briefcase me-1"></i> My Jobs
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Job" asp-action="Create">
                                        <i class="bi bi-plus-circle me-1"></i> Create Job
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Freelancer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="JobBrowse" asp-action="Index">
                                        <i class="bi bi-search me-1"></i> Browse Jobs
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Application" asp-action="MyApplications">
                                        <i class="bi bi-file-earmark-text me-1"></i> My Applications
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Category" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i> Manage Categories
                                    </a>
                                </li>
                            }
                        }

                    </ul>


                    <ul class="navbar-nav ms-auto">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- Notifications Dropdown -->
                            <li class="nav-item dropdown me-2" id="notificationDropdownContainer">
                                <a class="nav-link no-caret position-relative py-2" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="padding-left: 0.8rem; padding-right: 0.8rem;">
                                    <i class="bi bi-bell-fill text-muted transition-all" id="notificationBellIcon" style="font-size: 1.4rem;"></i>
                                    <span class="position-absolute badge rounded-pill bg-danger d-none" id="notificationBadge" style="top: 2px; right: 2px; font-size: 0.65rem; padding: 0.25em 0.5em;">
                                        0
                                    </span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu shadow-lg border-0 py-0" aria-labelledby="notificationDropdown" style="width: 320px; border-radius: 12px; overflow: hidden; margin-top: 10px;">
                                    <div class="dropdown-header d-flex justify-content-between align-items-center border-bottom px-3 py-2 bg-light">
                                        <h6 class="mb-0 fw-bold text-dark" style="font-size: 0.95rem;">Notifications</h6>
                                        <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 text-primary fw-semibold d-none" id="markAllAsReadBtn" style="font-size: 0.8rem; border-radius: 0; padding: 0;">Mark all as read</button>
                                    </div>
                                    <div class="notification-list" id="notificationList" style="max-height: 350px; overflow-y: auto;">
                                        <div class="text-center text-muted py-4" id="notificationEmptyState">
                                            <i class="bi bi-bell-slash fs-3 mb-2 d-block text-secondary"></i>
                                            <span style="font-size: 0.85rem;">No notifications yet</span>
                                        </div>
                                    </div>
                                </div>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle me-1"></i> Profile
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="LogOut">
                                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i> Login
                                </a>
                            </li>

                            @* <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i> Register
                                </a>
                            </li> *@
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <partial name="_Alerts" />
            @RenderBody()
        </main>
    </div>

  @*   <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Freelify - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
