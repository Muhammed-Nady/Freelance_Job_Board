@model EditFreelancerProfileViewModel

@{
    ViewData["Title"] = "Edit Freelancer Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex align-items-center mb-4">
                        <a asp-action="Index" class="btn btn-link text-decoration-none p-0 me-3 fs-4" title="Back to Profile">
                            <i class="bi bi-arrow-left"></i>
                        </a>
                        <h2 class="fw-bold m-0">Edit Freelancer Profile</h2>
                    </div>

                    <form asp-action="EditFreelancer" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ExistingProfileImageUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-3">
                            <!-- Full Name -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                    <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
                                </div>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <!-- Phone Number -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. +1234567890" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <!-- Profile Image File & Preview -->
                            <div class="col-12 mb-4">
                                <label asp-for="ProfileImage" class="form-label fw-semibold"></label>
                                <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border">
                                    <div class="flex-shrink-0">
                                        <img id="profile-preview" src="@(string.IsNullOrEmpty(Model.ExistingProfileImageUrl) ? "https://cdn-icons-png.flaticon.com/512/149/149071.png" : Model.ExistingProfileImageUrl)" 
                                             alt="Profile Preview" class="rounded-circle border border-2 border-white shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" />
                                    </div>
                                    <div class="flex-grow-1">
                                        <input asp-for="ProfileImage" class="form-control" type="file" accept="image/*" onchange="previewImage(this, 'profile-preview')" />
                                        <div class="form-text mt-1">Upload a professional photo.</div>
                                    </div>
                                </div>
                                <span asp-validation-for="ProfileImage" class="text-danger small"></span>
                            </div>

                            <!-- Bio -->
                            <div class="col-12 mb-3">
                                <label asp-for="Bio" class="form-label fw-semibold"></label>
                                <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Tell potential clients about yourself, your skills, and what makes you unique..."></textarea>
                                <span asp-validation-for="Bio" class="text-danger small"></span>
                            </div>

                            <!-- Experience -->
                            <div class="col-12 mb-4">
                                <label asp-for="Experience" class="form-label fw-semibold"></label>
                                <textarea asp-for="Experience" class="form-control" rows="5" placeholder="List your professional background, past roles, or notable projects..."></textarea>
                                <span asp-validation-for="Experience" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-end gap-2 border-top pt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input, previewId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById(previewId).src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
