@model ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="d-flex align-items-center mb-4">
                        <a asp-action="Index" class="btn btn-link text-decoration-none p-0 me-3 fs-4" title="Back to Profile">
                            <i class="bi bi-arrow-left"></i>
                        </a>
                        <h2 class="fw-bold m-0">Change Password</h2>
                    </div>

                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- Current Password -->
                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-key-fill"></i></span>
                                <input asp-for="CurrentPassword" class="form-control" type="password" placeholder="Enter current password" />
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <!-- New Password -->
                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="NewPassword" class="form-control" type="password" placeholder="Enter new password (min. 8 chars)" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            <div class="form-text text-muted small">
                                Password must be at least 8 characters long and contain at least one uppercase letter, one lowercase letter, and one digit.
                            </div>
                        </div>

                        <!-- Confirm New Password -->
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-shield-lock-fill"></i></span>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirm new password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 border-top pt-4 mt-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-lg me-2"></i> Update Password
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
