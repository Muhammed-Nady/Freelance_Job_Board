@using Freelify.Models.Enums
@using Freelify.Models.ViewModels.Job
@model JobBrowseViewModel

@{
    ViewData["Title"] = "Browse Jobs";
}

<div class="container py-5">

    <div class="row g-4">

		<!-- Jobs -->
		<div class="col-lg-9">

			<div class="d-flex justify-content-between align-items-center mb-3">

				<h3 class="fw-bold text-primary">

					Browse Jobs

				</h3>

				<span class="badge bg-primary rounded-pill fs-6">

					@Model.TotalCount Jobs

				</span>

			</div>

			<partial name="_Pager" model="Model" />

			@if (Model.Results.Any())
			{

				@foreach (var job in Model.Results)
				{

					<div class="card shadow-sm border-0 mb-4">

						<div class="card-body p-4">

							<div class="d-flex justify-content-between">

								<div>

									<h4 class="fw-bold mb-2">

										@job.Title

									</h4>

									<span class="badge bg-light text-dark border">

										@job.CategoryName

									</span>

								</div>

								<div class="text-end">

									<h5 class="text-success fw-bold">

										$@job.Budget

									</h5>

								</div>

							</div>

							<hr>

							<div class="row">

								<div class="col-md-4">

									<small class="text-muted">

										<i class="bi bi-building"></i>

										@job.ClientCompanyName

									</small>

								</div>

								<div class="col-md-4">

									<small class="text-muted">

										<i class="bi bi-calendar-event"></i>

										@job.Deadline.ToString("MMM dd, yyyy")

									</small>

								</div>

								<div class="col-md-4 text-md-end">

									<span class="badge bg-success">

										@job.Status

									</span>

								</div>

							</div>

							<div class="mt-4 text-end">

								<a asp-action="Details"
								   asp-route-id="@job.Id"
								   class="btn btn-primary">

									View Details

								</a>

							</div>

						</div>

					</div>

				}


			}
			else
			{

				<div class="card shadow-sm border-0">

					<div class="card-body text-center py-5">

						<i class="bi bi-search display-4 text-muted"></i>

						<h4 class="mt-3">

							No jobs found

						</h4>

						<p class="text-muted">

							Try changing your search filters.

						</p>

					</div>

				</div>

			}

		</div>
        <!-- Filter Sidebar -->
        <div  class="col-lg-3">

            <div class="card shadow-sm border-0 p-4">

                <h4 class="fw-bold text-primary mb-4">
                    <i class="bi bi-funnel-fill me-2"></i>
                    Filters
                </h4>

                 <form asp-action="Index" method="get">

                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Search
                        </label>

                        <input asp-for="SearchTerm"
                               class="form-control"
                               placeholder="Search jobs..." />
                    </div>

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Category
                        </label>

                        <select asp-for="CategoryId"
                                asp-items="Model.Categories"
                                class="form-select">

                            <option value="">All Categories</option>

                        </select>

                    </div>

                    <div class="mb-3">

                        <label class="form-label fw-semibold">
                            Skills
                        </label>

                        <select asp-for="SkillIds"
                                asp-items="Model.Skills"
                                class="form-select"
                                multiple>
                        </select>

                    </div>

                    <div class="row">

                        <div class="col">

                            <label class="form-label fw-semibold">
                                Min Budget
                            </label>

                            <input asp-for="MinBudget"
                                   class="form-control" />

                        </div>

                        <div class="col">

                            <label class="form-label fw-semibold">
                                Max Budget
                            </label>

                            <input asp-for="MaxBudget"
                                   class="form-control" />

                        </div>

                    </div>

                    <div class="mt-3">

                        <label class="form-label fw-semibold">
                            Sort By
                        </label>

                        <select asp-for="SortBy"
                                asp-items="Html.GetEnumSelectList<JobSortBy>()"
                                class="form-select">
                        </select>

                    </div>

                    <button class="btn btn-primary w-100 mt-4">

                        <i class="bi bi-search"></i>

                        Apply Filters

                    </button>

                </form> 

            </div>

        </div>



    </div>

</div>

@section Styles {

    <style>

        .card {
            border-radius: 15px;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
        }

        .btn {
            border-radius: 10px;
        }

    </style>

}