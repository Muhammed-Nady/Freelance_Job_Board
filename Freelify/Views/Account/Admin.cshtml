@model Freelify.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-5">

    <div class="mb-5">
        <h2 class="fw-bold">Admin Dashboard</h2>
        <p class="text-muted">
            Monitor platform statistics and activity.
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-people-fill display-5 text-primary"></i>

                    <h3 class="fw-bold mt-3">
                        @Model.TotalUsers
                    </h3>

                    <p class="text-muted mb-0">
                        Total Users
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-building display-5 text-success"></i>

                    <h3 class="fw-bold mt-3">
                        @Model.TotalClients
                    </h3>

                    <p class="text-muted mb-0">
                        Clients
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-person-workspace display-5 text-warning"></i>

                    <h3 class="fw-bold mt-3">
                        @Model.TotalFreelancers
                    </h3>

                    <p class="text-muted mb-0">
                        Freelancers
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-briefcase-fill display-5 text-info"></i>

                    <h3 class="fw-bold mt-3">
                        @Model.TotalJobs
                    </h3>

                    <p class="text-muted mb-0">
                        Total Jobs
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <i class="bi bi-file-earmark-text-fill display-5 text-danger"></i>

                    <h3 class="fw-bold mt-3">
                        @Model.TotalApplications
                    </h3>

                    <p class="text-muted mb-0">
                        Total Applications
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-5">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-semibold">
                    Quick Actions
                </h5>
            </div>

            <div class="card-body">

                <div class="d-flex flex-wrap gap-3">

                    <button class="btn btn-outline-primary" disabled>
                        Manage Users
                    </button>

                    <button class="btn btn-outline-success" disabled>
                        Manage Jobs
                    </button>

                    <button class="btn btn-outline-warning" disabled>
                        View Applications
                    </button>

                </div>

                <small class="text-muted d-block mt-3">
                    Optional features for future implementation.
                </small>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}