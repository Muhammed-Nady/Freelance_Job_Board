@model Freelify.Models.ViewModels.Job.JobDetailsViewModel

@{  
    ViewData["Title"] = "Job Details";
}

<div class="container py-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-1">@Model.Title</h2>
                            <span class="badge bg-primary">@Model.Status</span>
                        </div>

                            @if (User.IsInRole("Client"))
                            {
                                <a asp-action="MyJobs" class="btn btn-outline-secondary">
                                    Back
                                </a>
                            }
                            else
                            {
                                <a asp-controller="JobBrowse" asp-action="Index" class="btn btn-outline-secondary">
                                    Back
                                </a>
                            }

                    </div>

                    <hr />

                    <div class="row g-4">

                        <!-- Category -->
                        <div class="col-md-6">
                            <h6 class="text-muted">
                                <i class="bi bi-tag me-2"></i>Category
                            </h6>

                            <p class="fw-semibold">@Model.CategoryName</p>
                        </div>

                        <!-- Budget -->
                        <div class="col-md-6">
                            <h6 class="text-muted">
                                <i class="bi bi-cash-stack me-2"></i>Budget
                            </h6>

                            <p class="fw-semibold">$@Model.Budget</p>
                        </div>

                        <!-- Deadline -->
                        <div class="col-md-6">
                            <h6 class="text-muted">
                                <i class="bi bi-calendar-event me-2"></i>Deadline
                            </h6>

                            <p>@Model.Deadline.ToString("dd MMM yyyy")</p>
                        </div>

                        <!-- Posted -->
                        <div class="col-md-6">
                            <h6 class="text-muted">
                                <i class="bi bi-clock-history me-2"></i>Posted On
                            </h6>

                            <p>@Model.CreatedDate.ToString("dd MMM yyyy")</p>
                        </div>

                        <!-- Client -->
                        <div class="col-12">
                            <h6 class="text-muted">
                                <i class="bi bi-building me-2"></i>Client
                            </h6>

                            <p>@Model.ClientName</p>
                        </div>

                        @* Accepted freelancer info - show to client on job details page so they can rate without navigating *@
                        @if (Model.HasAcceptedFreelancer && User.IsInRole("Client")@*  && Model.ClientUserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value *@)
                        {
                            <div class="col-12">
                                <h6 class="text-muted">
                                    <i class="bi bi-person-check me-2"></i>Chosen Freelancer
                                </h6>

                                <div class="border rounded-3 p-3 bg-light d-flex justify-content-between align-items-center">
                                    <div>
                                        <p class="mb-1 fw-semibold">@Model.AcceptedFreelancerFullName</p>
                                    </div>

                                    <div>
                                        <form asp-controller="Review" asp-action="Create" method="post" class="d-flex gap-2 align-items-start">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="jobId" value="@Model.Id" />
                                            <input type="hidden" name="revieweeId" value="@Model.AcceptedFreelancerUserId" />

                                            <div class="me-2">
                                                <label class="form-label small mb-1">Rate</label>
                                                <select name="rating" class="form-select form-select-sm">
                                                    <option value="1">1</option>
                                                    <option value="2">2</option>
                                                    <option value="3">3</option>
                                                    <option value="4">4</option>
                                                    <option value="5" selected>5</option>
                                                </select>
                                            </div>

                                            <div class="me-2">
                                                <label class="form-label small mb-1">Comment</label>
                                                <input type="text" name="comment" class="form-control form-control-sm" placeholder="Optional comment" />
                                            </div>

                                            <div class="align-self-end">
                                                <button type="submit" class="btn btn-primary btn-sm">Submit Review</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Description -->
                        <div class="col-12">
                            <h6 class="text-muted">
                                <i class="bi bi-card-text me-2"></i>Description
                            </h6>

                            <div class="border rounded-3 p-3 bg-light">
                                @Model.Description
                            </div>
                        </div>

                        <!-- Skills -->
                        <div class="col-12">
                            <h6 class="text-muted">
                                <i class="bi bi-tools me-2"></i>Required Skills
                            </h6>

                            @if (Model.Skills.Any())
                            {
                                @foreach (var skill in Model.Skills)
                                {
                                    <span class="badge bg-secondary me-2 mb-2">
                                        @skill
                                    </span>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No skills specified.</p>
                            }
                        </div>

                        <!-- Attachments -->
                        <div class="col-12">
                            <h6 class="text-muted">
                                <i class="bi bi-paperclip me-2"></i>Attachments
                            </h6>

                            @if (Model.AttachmentPaths.Any())
                            {
                                <ul class="list-group">
                                    @foreach (var file in Model.AttachmentPaths)
                                    {
                                        <li class="list-group-item">
                                            <a href="@file" target="_blank">
                                                <i class="bi bi-file-earmark-arrow-down me-2"></i>
                                                @System.IO.Path.GetFileName(file)
                                            </a>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted">No attachments.</p>
                            }
                        </div>

                    </div>

                    <div class="border-top mt-5 pt-4 d-flex justify-content-end gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Freelancer") && Model.Status == "Open")
                            {
                                <a asp-controller="Application" asp-action="Create" asp-route-jobId="@Model.Id" class="btn btn-success">
                                    <i class="bi bi-send me-2"></i>Apply Now
                                </a>
                            }

                            @if (User.IsInRole("Client") && Model.ClientUserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <a asp-controller="Application" asp-action="ForJob" asp-route-jobId="@Model.Id" class="btn btn-primary">
                                    <i class="bi bi-file-earmark-person me-2"></i>View Proposals
                                </a>
                                @if (Model.Status == "InProgress")
                                {
                                    <form asp-action="MarkComplete"
                                          asp-controller="Job"
                                          asp-route-Jobid="@Model.Id"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to mark this job as completed?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-success">
                                            <i class="bi bi-check-circle me-2"></i>Complete Job
                                        </button>
                                    </form>
                                }
                            }
                        }
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>