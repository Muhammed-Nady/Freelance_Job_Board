@model Freelify.Models.ViewModels.Job.JobEditViewModel

@{
    ViewData["Title"] = "Edit Job";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">

                    <div class="d-flex align-items-center mb-4">
                        <a asp-action="MyJobs"
                           class="btn btn-link text-decoration-none p-0 me-3 fs-4"
                           title="Back">
                            <i class="bi bi-arrow-left"></i>
                        </a>

                        <h2 class="fw-bold m-0">
                            Edit Job
                        </h2>
                    </div>

                    <form asp-action="Edit" method="post" enctype="multipart/form-data">

                        @Html.AntiForgeryToken()

                        <input asp-for="Id" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <div class="row g-3">

                            <!-- Job Title -->
                            <div class="col-12">
                                <label asp-for="Title" class="form-label fw-semibold"></label>

                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-briefcase"></i>
                                    </span>

                                    <input asp-for="Title"
                                           class="form-control"
                                           placeholder="Enter job title" />
                                </div>

                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <!-- Category -->
                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label fw-semibold"></label>

                                <select asp-for="CategoryId"
                                        asp-items="ViewBag.Categories"
                                        class="form-select">
                                    <option value="">Select Category</option>
                                </select>

                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <!-- Budget -->
                            <div class="col-md-6">
                                <label asp-for="Budget" class="form-label fw-semibold"></label>

                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-cash-stack"></i>
                                    </span>

                                    <input asp-for="Budget"
                                           class="form-control"
                                           placeholder="Enter budget" />
                                </div>

                                <span asp-validation-for="Budget" class="text-danger small"></span>
                            </div>

                            <!-- Deadline -->
                            <div class="col-md-6">
                                <label asp-for="Deadline" class="form-label fw-semibold"></label>

                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-calendar-event"></i>
                                    </span>

                                    <input asp-for="Deadline"
                                           type="date"
                                           class="form-control" />
                                </div>

                                <span asp-validation-for="Deadline" class="text-danger small"></span>
                            </div>

                            <!-- Skills -->
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Skills
                                </label>

                                <select asp-for="SelectedSkillIds"
                                        asp-items="ViewBag.Skills"
                                        id="skills"
                                        multiple>
                                </select>


                                <small class="text-muted">
                                    Hold Ctrl (Windows) or Cmd (Mac) to select multiple skills.
                                </small>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label asp-for="Description" class="form-label fw-semibold"></label>

                                <textarea asp-for="Description"
                                          rows="6"
                                          class="form-control"
                                          placeholder="Describe the project, requirements, deliverables, and expectations..."></textarea>

                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <!-- Attachments -->
                            <div class="col-12">
                                <label asp-for="Attachments" class="form-label fw-semibold"></label>

                                <input asp-for="Attachments"
                                       type="file"
                                       multiple
                                       class="form-control" />

                                <span asp-validation-for="Attachments" class="text-danger small"></span>
                            </div>

                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-4 mt-4">

                            <a asp-action="MyJobs"
                               class="btn btn-outline-secondary">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-4">
                                <i class="bi bi-save me-2"></i>
                                Save Changes
                            </button>

                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_ValidationScriptsPartial"/>

    <script>
        new TomSelect("#skills",{
            plugins:['remove_button'],
            create:false,
            placeholder:"Select required skills..."
        });
    </script>
}
