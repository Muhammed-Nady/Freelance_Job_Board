@model List<Freelify.Models.Entities.Job>

@{
    ViewData["Title"] = "My Jobs";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">My Jobs</h2>

        <a asp-action="Create"
           class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>
            Post New Job
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't posted any jobs yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @foreach (var job in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="card shadow-sm h-100 border-0 rounded-4">

                        <div class="card-body p-4 d-flex flex-column">

                            <h4 class="fw-bold mb-2">
                                @job.Title
                            </h4>

                            <p class="text-muted mb-3">
                                @job.Category.Name
                            </p>

                            <p class="mb-4 text-secondary">
                                @(job.Description.Length > 120
                                    ? job.Description[..120] + "..."
                                    : job.Description)
                            </p>

                            <hr class="my-3" />

                            <div class="d-flex justify-content-between align-items-center mb-3">

                                <span class="fw-semibold">
                                    💰 @job.Budget $
                                </span>

                                <span class="badge bg-success">
                                    @job.Status
                                </span>

                            </div>

                            <div class="text-muted mt-auto">
                                <i class="bi bi-calendar-event me-1"></i>
                                Deadline:
                                @job.Deadline.ToString("dd MMM yyyy")
                            </div>

                        </div>

                        <div class="card-footer bg-white border-top-0 px-4 pb-4 pt-2">

                            <div class="d-flex gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@job.Id"
                                   class="btn btn-outline-primary flex-fill">
                                    Details
                                </a>
            
                                <a asp-action="Edit"
                                   asp-route-id="@job.Id"
                                   class="btn btn-outline-secondary flex-fill"
                                >
                                    Edit
                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@job.Id"
                                      method="post"
                                      class="flex-fill">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-outline-danger w-100"
                                            onclick="return confirm('Are you sure you want to delete this job?')">
                                        Delete
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>