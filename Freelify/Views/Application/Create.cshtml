@model Freelify.Models.ViewModels.Application.ApplicationCreateViewModel

@{
    ViewData["Title"] = "Submit Proposal";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white py-3 border-0">
                    <h2 class="h4 mb-0 text-gray-800">
                        <i class="bi bi-file-earmark-text-fill text-primary me-2"></i>Submit Proposal for "@ViewBag.JobTitle"
                    </h2>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="JobId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CoverLetter" class="form-label fw-semibold">Cover Letter</label>
                            <textarea asp-for="CoverLetter" class="form-control" rows="8" placeholder="Describe why you are the best fit for this job..."></textarea>
                            <span asp-validation-for="CoverLetter" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="BidAmount" class="form-label fw-semibold">Bid Amount ($)</label>
                                <input asp-for="BidAmount" class="form-control" type="number" step="0.01" placeholder="e.g., 500" />
                                <span asp-validation-for="BidAmount" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EstimatedCompletionDays" class="form-label fw-semibold">Estimated Days to Complete</label>
                                <input asp-for="EstimatedCompletionDays" class="form-control" type="number" placeholder="e.g., 10" />
                                <span asp-validation-for="EstimatedCompletionDays" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Attachments" class="form-label fw-semibold">Attachments (optional)</label>
                            <input asp-for="Attachments" class="form-control" type="file" multiple />
                            <small class="text-muted d-block mt-1">Allowed extensions: .pdf, .doc, .docx, .jpg, .png. Max size: 10MB per file.</small>
                            <span asp-validation-for="Attachments" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-controller="JobBrowse" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Back to Jobs
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-1"></i> Submit Proposal
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
