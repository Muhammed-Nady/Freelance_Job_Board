@model Freelify.Models.ViewModels.Application.ApplicationDetailsViewModel

@{
    ViewData["Title"] = "Proposal Details";
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0 text-gray-800">
                    <i class="bi bi-file-text-fill text-primary me-2"></i>Proposal Details
                </h1>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Application"
                       asp-action="ForJob"
                       asp-route-jobId="@Model.JobId"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to Applications
                    </a>
                }
                else if (User.IsInRole("Client"))
                {
                    <a asp-action="ForJob"
                       asp-route-jobId="@Model.JobId"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to Proposals
                    </a>
                }
                else
                {
                    <a asp-action="MyApplications"
                       class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Back to My Applications
                    </a>
                }
            </div>

            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0 text-muted">Job Title: <span class="text-dark fw-bold">@Model.JobTitle</span></h2>
                        @{
                            string badgeClass = Model.Status switch
                            {
                                Freelify.Models.Enums.ApplicationStatus.Accepted => "bg-success",
                                Freelify.Models.Enums.ApplicationStatus.Rejected => "bg-danger",
                                Freelify.Models.Enums.ApplicationStatus.UnderReview => "bg-info text-dark",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass fs-6">@Model.Status</span>
                    </div>

                    <hr />

                    <div class="row g-4 my-2">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <span class="text-muted d-block small mb-1">Bid Amount</span>
                                <span class="fs-4 fw-bold text-primary">$@Model.BidAmount.ToString("N2")</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-3">
                                <span class="text-muted d-block small mb-1">Estimated Completion</span>
                                <span class="fs-4 fw-bold text-dark">@Model.EstimatedCompletionDays Days</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <h3 class="h6 fw-bold text-uppercase text-muted mb-2">Cover Letter</h3>
                        <div class="p-3 border rounded bg-white text-dark shadow-sm" style="white-space: pre-line; line-height: 1.6; min-height: 150px;">
                            @Model.CoverLetter
                        </div>
                    </div>

                    @if (Model.Attachments.Any())
                    {
                        <div class="mt-4">
                            <h3 class="h6 fw-bold text-uppercase text-muted mb-2">Attachments</h3>
                            <div class="list-group">
                                @foreach (var att in Model.Attachments)
                                {
                                    <a asp-action="DownloadAttachment" asp-route-id="@att.Id" class="list-group-item list-group-item-action d-flex align-items-center border-0 rounded-3 bg-light mb-2 shadow-sm">
                                        <i class="bi bi-file-earmark-arrow-down-fill text-primary fs-4 me-3"></i>
                                        <div>
                                            <span class="d-block fw-semibold text-dark">@att.FileName</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-header bg-white py-3 border-0">
                    <h3 class="h5 mb-0 text-gray-800">
                        <i class="bi bi-person-fill text-primary me-2"></i>Freelancer Profile Summary
                    </h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Full Name</div>
                        <div class="col-sm-9 fw-semibold text-dark">@Model.FreelancerFullName</div>
                    </div>
                    @if (User.IsInRole("Client"))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-3 text-muted">Email Contact</div>
                            <div class="col-sm-9 text-dark">@Model.FreelancerEmail</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-3 text-muted">Phone Number</div>
                            <div class="col-sm-9 text-dark">@Model.FreelancerPhoneNumber</div>
                        </div>
                    }
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Freelancer Bio</div>
                        <div class="col-sm-9 text-dark" style="white-space: pre-line;">@Model.FreelancerBio</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Experience Details</div>
                        <div class="col-sm-9 text-dark" style="white-space: pre-line;">@Model.FreelancerExperience</div>
                    </div>
                </div>
            </div>

            @if (User.IsInRole("Client") && (Model.Status == Freelify.Models.Enums.ApplicationStatus.Submitted || Model.Status == Freelify.Models.Enums.ApplicationStatus.UnderReview))
            {
                <div class="card shadow-sm border-0 rounded-3 mb-4">
                    <div class="card-body p-4 d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="h5 fw-bold mb-1">Decide on this Proposal</h4>
                            <p class="text-muted small mb-0">Accepting this proposal will automatically decline all other proposals for this job.</p>
                        </div>
                        <div class="d-flex gap-2">
                            <form asp-action="Accept" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Accepting this proposal will change the job status to In Progress and reject all other proposals. Proceed?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success px-4 shadow-sm">
                                    <i class="bi bi-check-lg me-1"></i> Accept
                                </button>
                            </form>
                            <form asp-action="Reject" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to reject this proposal?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger px-4 shadow-sm">
                                    <i class="bi bi-x-lg me-1"></i> Reject
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
