@model IEnumerable<Freelify.Models.ViewModels.Application.ApplicationListItemViewModel>

@{
    ViewData["Title"] = "My Applications";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0 text-gray-800">
            <i class="bi bi-file-earmark-text-fill text-primary me-2"></i>My Applications
        </h1>
        <a asp-controller="JobBrowse" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-search me-1"></i> Browse More Jobs
        </a>
    </div>

    @* @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    } *@

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Job Title</th>
                            <th>Bid Amount</th>
                            <th>Estimated Duration</th>
                            <th>Submitted Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    <i class="bi bi-info-circle display-6 d-block mb-2"></i>
                                    You have not submitted any proposals yet.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                string badgeClass = item.Status switch
                                {
                                    Freelify.Models.Enums.ApplicationStatus.Accepted => "bg-success",
                                    Freelify.Models.Enums.ApplicationStatus.Rejected => "bg-danger",
                                    Freelify.Models.Enums.ApplicationStatus.UnderReview => "bg-info text-dark",
                                    _ => "bg-secondary"
                                };

                                <tr>
                                    <td class="ps-4 fw-semibold">@item.JobTitle</td>
                                    <td class="fw-semibold text-primary">$@item.BidAmount.ToString("N2")</td>
                                    <td>@item.EstimatedCompletionDays Days</td>
                                    <td>@item.SubmittedDate.ToString("MMMM dd, yyyy")</td>
                                    <td>
                                        <span class="badge @badgeClass fs-6">@item.Status</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye-fill me-1"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
