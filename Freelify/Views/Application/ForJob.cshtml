@model IEnumerable<Freelify.Models.ViewModels.Application.ApplicationListItemViewModel>

@{
    ViewData["Title"] = "Job Proposals";
}

<div class="container my-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h2 mb-0 text-gray-800">
                <i class="bi bi-file-earmark-person-fill text-primary me-2"></i>Proposals for "@ViewBag.JobTitle"
            </h1>
        </div>
        <div class="col text-end">
            <a asp-controller="Job" asp-action="MyJobs" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to My Jobs
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-3">
            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-info-circle display-6 d-block mb-2"></i>
                    No proposals have been submitted for this job yet.
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var item in Model)
                    {
                        <div class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3">
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(item.FreelancerProfileImageUrl))
                                {
                                    <a asp-controller="Profile" asp-action="PublicFreelanser" asp-route-id="@item.FreelancerProfileId" target="_blank">
                                        <img src="@item.FreelancerProfileImageUrl" alt="@item.FreelancerUserName" class="rounded-circle" style="width:48px;height:48px;object-fit:cover;" />
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Profile" asp-action="PublicFreelanser" asp-route-id="@item.FreelancerProfileId" target="_blank">
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width:48px;height:48px;font-weight:600;">
                                            @((!string.IsNullOrEmpty(item.FreelancerUserName) ? item.FreelancerUserName[0] : 'U'))
                                        </div>
                                    </a>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <a asp-controller="Profile" asp-action="PublicFreelanser" asp-route-id="@item.FreelancerProfileId" class="text-decoration-none fw-semibold text-dark" target="_blank">
                                            @item.FreelancerUserName
                                        </a>
                                        <div class="text-muted small">@item.FreelancerFullName</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-semibold text-primary">$@item.BidAmount.ToString("N2")</div>
                                        <div class="text-muted small">@item.EstimatedCompletionDays Days</div>
                                    </div>
                                </div>

                                <div class="mt-2 text-muted small">
                                    @{
                                        var preview = string.IsNullOrEmpty(item.CoverLetter) ? "" : (item.CoverLetter.Length > 180 ? item.CoverLetter.Substring(0, 180) + "..." : item.CoverLetter);
                                    }
                                    @preview
                                </div>

                                <div class="mt-2 d-flex justify-content-between align-items-center">
                                    <div class="text-muted small">@item.SubmittedDate.ToString("MMMM dd, yyyy")</div>
                                    <div>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
